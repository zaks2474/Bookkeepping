[Unit]
Description=Claude Code OpenWebUI API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/home/zaks/claude-code-openwebui
ExecStart=/usr/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8090
Restart=always
RestartSec=10
Environment=PATH=/root/.npm-global/bin:/usr/local/bin:/usr/bin:/bin

[Install]
WantedBy=multi-user.target
